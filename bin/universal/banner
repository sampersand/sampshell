#!/usr/bin/env ruby
# frozen_string_literal: true

################################################################################
# Banner: Surround messages in boxes, to use for separators in source files.   #
################################################################################
require 'optparse2'
require 'gvars'

# The styles that are recognized
class Style
  def initialize(top:, bottom:, prefix:, suffix:, &block)
    @top, @bottom, @prefix, @suffix = top, bottom, prefix, suffix
    instance_exec(&block) if defined? yield
  end

  def style_width = @prefix.length + @suffix.length
  def top(width) = @top.call(width)
  def bottom(width) = @bottom.call(width)

  attr_reader :prefix, :suffix
end

STYLES = {
  '#' => Style.new(
    top:    ->(width){ ['#' * width] },
    bottom: ->(width){ ['#' * width] },
    prefix: '#',
    suffix: '#',
  ),
  '/' => Style.new(
    top:    ->(width){ ['/' * width] },
    bottom: ->(width){ ['/' * width] },
    prefix: '//',
    suffix: '//',
  ),
  '*' => Style.new(
    top:    ->(width){ ['/', '*' * (width - 2)] },
    bottom: ->(width){ [' ', '*' * (width - 2), '/'] },
    prefix: ' *',
    suffix: '*',
  ) { def style_width = super + 1 },
}.freeze

# How text can be aligned
JUSTIFIES = {
  'l' => :ljust,  'left'  => :ljust,
  'r' => :rjust,  'right' => :rjust,
  'c' => :center, 'center' => :center
}.freeze

# class OptParse2
  # module SetReason

# Parse options out
OptParse2.new do |op|
  op.accept :width do |arg|
    arg == 'auto' ? 0 : (Integer arg rescue raise OptParse::InvalidArgument)
  end

  op.on '--debug', hidden: true

  op.on '-w', '--width=WIDTH|auto',  :width,  'Total banner width; use "auto" (or 0) to fit text', default: 80
  op.on '-p', '--pre=SPACES',        Integer, 'Indent the banner by SPACES',                       default: 0
  op.on '-t', '-x', '--tab[=WIDTH]', Integer, 'Use tabs for indentation; WIDTH is tab size (default: 4)',
                                              'Leftover indentation is filled with spaces' do |width|
    width || 4
  end

  op.on '-s', '--style=STYLE',  STYLES,    "Banner style [options: #{STYLES.keys.join ', '}]",            default: STYLES['#'], default_description: '#'
  op.on '-j', '--justify=HOW',  JUSTIFIES, 'Justify text: l/left, r/ight, c/center',                      default: :center
  op.on       '--[no-]padding',            'Pad each message with leading and trailing spaces if needed', default: true

  op.on '-m', '--multiline', 'Treat each argument as a separate line'
  op.on '-b', '--blank',     'Add an empty line above and below the message'
  op.on '-c', '--copy',      'Copy output to macOS clipboard'

  op.rest 'message', 'Message text to display', required: 1

  op.parse! into: GVars, abort: true
end

####################################################################################################
#                                   Handle Command-line Options                                    #
####################################################################################################

# Make sure that if `--tab` was supplied, a `--pre` was also given
if $tab
  abort '--tab requires --pre to set indentation width' if $pre.zero?
end

# Write messages to the macos clipboard if `--copy` was given
$stdout = IO.popen('pbcopy', 'w') if $copy

# Join all arguments together into a single string, unless `--multiline` was given
$message.replace [$message.join(' ')] unless $multiline

# If padding is given (the default), add a space before and after each line
$message.map! { |line| " #{line} " } if $padding

# Add a blank line before and after the messages if `--blank` was supplied
$message.unshift('').push('') if $blank

####################################################################################################
#                                         Calculate Width                                          #
####################################################################################################

# Calculate the width if an auto width was requested.
if $width.zero?
  $width = $pre + $message.map(&:length).max + $style.style_width
end

# If debug mode is enabled, prints out a table prefix so we can see widths
if $debug
  ($width.to_s.length - 1).downto 0 do |r|
    puts (1..$width).map { |x| ((x / 10 ** r) % 10).to_s }.join
  end
end

# Now remove the prefix length from the width
$width -= $pre # TODO: use a `MASTER_WIDTH` or something

# Validate the width is positive, and messages can fit in it
if $width.negative?
  abort "--pre (#$pre) is greater than --width (#{$width + $pre}); no space remains for text"
elsif $width < (max_msg_width = $message.map(&:length).max)
  abort "message is too wide (#{max_msg_width}) for --width (#$width after indentation)"
end

####################################################################################################
#                                          Business Logic                                          #
####################################################################################################

# TODO: simplify?
PREFIX = if $tab
  "\t" * ($pre / $tab) + " " * ($pre % $tab)
else
  ' ' * $pre
end

# Like `print`, except it prepends any `--pre` that was given
def print_prefixed(*a)
  print(PREFIX, *a, "\n")
end

print_prefixed(*$style.top($width))

MSG_WIDTH = $width - $style.style_width
$message.each do |line|
  print_prefixed $style.prefix, line.public_send($justify, MSG_WIDTH), $style.suffix
end
print_prefixed(*$style.bottom($width))
