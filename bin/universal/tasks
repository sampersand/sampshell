#!/usr/bin/env ruby

require 'optparse2'
require 'optparse2/pathname'
require 'time'
require 'xdg'
require 'json'
require 'securerandom'

class Task
  attr_reader :uuid
  attr_accessor :due, :complete, :message, :priority, :estimate

  def self.create(**) = new(uuid: SecureRandom.uuid, **)

  def self.from_json(json)
    json => { due:, **rest }
    new(due: Time.parse(due), **rest)
  end

  def initialize(uuid:, due:, complete:, message:, priority:, estimate: nil)
    @uuid, @due, @complete, @message, @priority, @estimate = uuid, due, complete, message, priority, estimate
  end

  alias complete? complete

  def to_h = { uuid:, due:, complete:, message:, priority:, estimate: }.compact
  def to_json(...) = to_h.to_json(...)

  def short_uuid = uuid[/^[^-]*/]
  def uuid_matches?(other) = uuid.start_with?(other)

  def to_pretty_s = "#{complete? ? '✔' : '✘'}#{overdue? ? '!!!!' : ''} #{short_uuid} #{due} [#{priority}#{estimate && " @ #{estimate_s}"}] #{message}"
  def to_s = "#{short_uuid} #{message}"

  def estimate_s
    return '0s' if @estimate.zero?
    hr, sec = @estimate.divmod 60
    "#{hr > 0 ? "#{hr}h" : nil}#{sec > 0 ? "#{sec}m" : nil}"
  end

  def overdue? = Time.now > @due
end

class Tasks
  attr_accessor :tasks

  def initialize(path)
    @path = path
    acquire_lock_file!

    @tasks = JSON.unsafe_load(@path, symbolize_names: true)&.map { Task.from_json(it) } || []
  end

  def acquire_lock_file!
    if !@path.exist?
      @path.parent.mkpath
      @path.write '[]'
    end

    @lockfile = Pathname(@path.to_s + '.lock')

    if @lockfile.exist?
      raise "lockfile #@lockfile already held"
    else
      open @lockfile, 'a' do |l| l.write $$.to_s end
      raise "lockfile #@lockfile already held" if @lockfile.read != $$.to_s
      at_exit { @lockfile.delete rescue nil }
    end
  end

  include Enumerable
  def each(...) = @tasks.each(...)

  def add(...)
    task = Task.create(...)
    @tasks.push task
    task
  end

  def write!(tasks = @tasks)
    open @path, 'w' do |file|
      file.puts tasks.to_json
    end
  end

  class UUIDMatchError < RuntimeError; end

  def find_task(uuid)
    matching_tasks = select { it.uuid_matches? uuid }

    case matching_tasks.length
    when 0
      raise UUIDMatchError, "uuid does not exist: #{uuid}"
    when 1
      return matching_tasks.first
    else
      raise UUIDMatchError, "uuid matches multiple: #{matching_tasks.map(&:uuid)}"
    end
  end
end

op = OptParse2.new
op.on '--current-todo-file=FILE', Pathname, 'Where to locate todos',
  default: proc{ XDG.new.state_home / 'sampshell' / 'todos' / 'current' },
  default_description: '$XDG_CACHE_HOME/sampshell/todos/current'

op.accept :due do |arg|
  time = Time.parse(arg)
end

op.accept :priority, /\A[0-4]\z/, &:to_i

op.accept :estimate do |arg|
  arg =~ /\A(?:\s*(\d+)\s*[hH]\b)?(?:\s*(\d+)\s*[mM]?)?\s*\z/ or
    arg =~ /\A\s*(\d+)\s*:\s*(\d+)\s*\z/ or raise OptParse2::InvalidArgument
  raise OptParse2::InvalidArgument if $1.nil? && $2.nil?
  ($1&.to_i&.*(60) || 0) + ($2&.to_i || 0)
end

def op.parse_and_tasks!(opts)
  parse! into: opts
  Tasks.new opts.delete(:'current-todo-file')
end

def op.help!
  banner.concat ' subcommand [...]'
  on_head 'General Options:'
  on 'Subcommands:'
  on '  h,help      Print this help message'
  on '  l,list      Read the current todo list'
  on '  n,new,a,add Create a new todo'
  on '  c,complete  Mark a todo as complete'
  on '  m,modify    Modify a TODO'
  help_exit
end

def op.list!
  banner.concat ' [specific uuids]'
  on '-j', '--json', 'Output as JSON, instead of human-readable'
  on '--pretty-json', 'Output as pretty JSON'
  on '-a', '--all', 'Also output TODOs which are complete [default just shows what is left]'
  on '-o', '--[no-]overdue', 'Only print overdue (or not overdue)'
  on '-p', '--priority=INTEGER', :priority, 'Only print tasks with the given priority'

  tasks = parse_and_tasks!(opts = {}).to_a
  unless $*.empty?
    tasks.select! { |task| $*.any? { task.uuid_matches? it } }
  end
  tasks.reject!(&:complete?) unless opts[:all]
  tasks.select! { it.priority == opts[:priority] } if opts[:priority]

  out = []
  out.concat tasks.select(&:overdue?).sort_by(&:priority) unless opts[:overdue] == false
  out.concat tasks.reject(&:overdue?).sort_by(&:priority) unless opts[:overdue] == true

  if opts[:'pretty-json']
    puts JSON.pretty_generate out
  elsif opts[:json]
    puts out.to_json
  else
    puts out.map(&:to_pretty_s)
  end
end

def op.new!
  banner.concat ' [message, if not given via -m]'
  on '-d', '--due=WHEN', :due, 'When the task is due [optional; defaults to tomorrow]', default: (Time.now + 24*60*60)
  on '-c', '--complete', 'Already mark as already completed'
  on '-m', '--message=STRING', 'Explicitly set the message (you can also use cmdline args)'
  on '-p', '--priority=INTEGER', :priority, 'How important it is (0 is most important)', default: 2
  on '-e', '--estimate=TIME', :estimate, 'How many minutes it will take take'

  tasks = parse_and_tasks!(opts = {})
  if opts.fetch(:message, '').empty? ^ !$*.empty?
    abort 'exactly one of -m or command-line args can eb used to supply the message'
  end

  task = tasks.add(
    due: opts[:due].to_time,
    complete: !!opts[:complete],
    message: opts[:message] || $*.join(' '),
    priority: opts[:priority],
    estimate: opts[:estimate],
  )

  tasks.write!
  puts "create task: #{task}"
end

def op.complete!
  banner.concat ' [uuids to complete]'
  on '-u', '--uncomplete', 'Mark tasks as uncompleted, instead of completed'

  tasks = parse_and_tasks!(opts = {})
  $*.empty? and abort 'at least one uuid must be given'

  success = true
  $*.each do |uuid|
    task = tasks.find_task(uuid)
    task.complete = !opts[:uncomplete]
    puts "marked task as #{opts[:uncomplete] ? "un" : ""}complete: #{task}"
  rescue UUIDMatchError => err
    warn err
    success = false
  end

  tasks.write!
  exit success
end

def op.modify!
  banner.concat ' (uuid to modify)'

  on       '--delete', 'Completely deletes the task (dangerous! prefer --complete instead)'
  on '-c', '--complete', 'Mark task as completed'
  on '-u', '--uncomplete', 'Mark task as uncompleted, instead of completed', key: :complete do false end
  on '-d', '--due=WHEN', :due, 'Modify due date'
  on '-m', '--message=WHAT', 'Set the task message'
  on '-p', '--priority=INTEGER', Integer, 'How important it is (0 is most important)'
  on '-e', '--estimate=TIME', :estimate, 'How many minutes it will take take'

  tasks = parse_and_tasks!(opts = {})
  uuid = $*.shift
  uuid.nil? || !$*.empty? and abort 'exactly one uuid must be given'

  task = begin tasks.find_task(uuid); rescue UUIDMatchError; abort end

  (task.complete = opts[:complete]; puts "changed complete to #{opts[:complete]} for: #{task}") if opts.key?(:complete)
  (task.due = opts[:due]; puts "changed due to #{opts[:due]} for: #{task}") if opts.key?(:due)
  (task.message = opts[:message]; puts "changed message to #{opts[:message]} for: #{task}") if opts.key?(:message)
  (task.priority = opts[:priority]; puts "changed priority to #{opts[:priority]} for: #{task}") if opts.key?(:priority)
  (task.estimate = opts[:estimate]; puts "changed estimate to #{opts[:estimate]} for: #{task}") if opts.key?(:estimate)

  if opts[:delete]
    tasks.tasks.delete task
    warn "deleted task: #{task}"
  end

  tasks.write!
end


case (cmd = $*.shift)
when '_' then puts XDG.new.state_home / 'sampshell' / 'todos' / 'current'
when 'l', 'list' then op.list!
when 'n', 'new', 'a', 'add' then op.new!
when 'c', 'complete' then op.complete!
when 'm', 'modify' then op.modify!
when nil, 'h', 'help' then op.help!
else op.abort "unknown command: #{cmd}; use #{op.program_name} help"
end
