#!/usr/bin/env ruby

require 'optparse2'
require 'optparse2/pathname'
require 'time'
require 'xdg'
require 'json'
require 'securerandom'

class Task
  attr_reader :uuid
  attr_accessor :due, :complete, :message, :priority, :estimate, :tags

  def self.create(**) = new(uuid: SecureRandom.uuid, **)

  def self.from_json(json)
    json = json.dup
    json[:due] &&= Time.parse json[:due]
    new(**json)
  end

  def initialize(uuid:, due: nil, complete:, message:, priority: nil, estimate: nil, tags: [])
    @uuid, @due, @complete, @message, @priority, @estimate, @tags = uuid, due, complete, message, priority, estimate, tags
  end

  alias complete? complete

  def to_h = { uuid:, due:, complete:, message:, priority:, estimate:, tags: }.compact
  def to_json(...) = to_h.to_json(...)

  def short_uuid = uuid[/^[^-]*/]
  def uuid_matches?(other) = uuid.start_with?(other)

  def k(c,m) = "\e[38;5;#{m}mP#{c}\e[39m"
  def to_pretty_s
    pr = { 0 => k(0, 196),
      1 => k(1, 1),
      2 => k(2, 130),
      3 => k(3, 66),
      4 => k(4, 242),
      nil => nil }.fetch(priority, priority)
    tag_s = tags.empty? ? nil : tags.map { |tag|
      {
        'dog' => '🐶',
        'house' => '🏠',
        'wedding'=> '💍',
      }.fetch(tag, &:inspect)
    }.join
    "#{overdue? ? "\e[48;5;196m" : ''}#{complete? ? '✔' : '✘'} #{due&.to_date || ' '*10} #{short_uuid} [#{pr}#{estimate && " @ #{estimate_s}"}] #{tag_s}#{tag_s && ' '}#{message}#{overdue? ? "\e[49m" : ""}"
  end


  def to_s = "#{short_uuid} #{message}"

  def estimate_s
    return '0s' if @estimate.zero?
    hr, sec = @estimate.divmod 60
    "#{"#{hr}h" if 0 < hr}#{"#{sec}m" if 0 < sec}"
  end

  def overdue? = due && Time.now > due
end

class Tasks
  attr_accessor :tasks

  def initialize(path)
    @path = path
    acquire_lock_file!

    @tasks = JSON.unsafe_load(@path, symbolize_names: true)&.map { Task.from_json(it) } || []
  end

  def acquire_lock_file!
    if !@path.exist?
      @path.parent.mkpath
      @path.write '[]'
    end

    @lockfile = Pathname(@path.to_s + '.lock')

    if @lockfile.exist?
      raise "lockfile #@lockfile already held"
    else
      open @lockfile, 'a' do |l| l.write $$.to_s end
      raise "lockfile #@lockfile already held" if @lockfile.read != $$.to_s
      at_exit { @lockfile.delete rescue nil }
    end
  end

  include Enumerable
  def each(...) = @tasks.each(...)

  def add(...)
    task = Task.create(...)
    @tasks.push task
    task
  end

  def write!(tasks = @tasks)
    open @path, 'w' do |file|
      file.puts tasks.to_json
    end
  end

  class UUIDMatchError < RuntimeError; end

  def find_task(uuid)
    matching_tasks = select { it.uuid_matches? uuid }

    case matching_tasks.length
    when 0
      raise UUIDMatchError, "uuid does not exist: #{uuid}"
    when 1
      return matching_tasks.first
    else
      raise UUIDMatchError, "uuid matches multiple: #{matching_tasks.map(&:uuid)}"
    end
  end
end

op = OptParse2.new
op.on '--current-todo-file=FILE', Pathname, 'Where to locate todos',
  default: proc{ XDG.new.state_home / 'sampshell' / 'todos' / 'current' },
  default_description: '$XDG_CACHE_HOME/sampshell/todos/current'
op.banner = "usage: #{op.program_name} [options]"

op.accept :due do |arg|
  time = Time.parse(arg)
end

op.accept :priority, /\A[0-4]\z/, &:to_i

op.accept :estimate do |arg|
  arg =~ /\A(?:\s*(\d+)\s*[hH]\b)?(?:\s*(\d+)\s*[mM]?)?\s*\z/ or
    arg =~ /\A\s*(\d+)\s*:\s*(\d+)\s*\z/ or raise OptParse2::InvalidArgument
  raise OptParse2::InvalidArgument if $1.nil? && $2.nil?
  ($1&.to_i&.*(60) || 0) + ($2&.to_i || 0)
end

def op.parse_and_tasks!(opts)
  parse! into: opts
  Tasks.new opts.delete(:'current-todo-file')
end

def op.help!
  banner.concat ' subcommand [...]'
  on_head 'General Options:'
  on 'Subcommands:'
  on '  help      Print this help message'
  on '  list      Read the current todo list'
  on '  new,add Create a new todo'
  on '  complete  Mark a todo as complete'
  on '  modify    Modify a TODO'
  help_exit
end

def op.list!
  banner.concat ' [specific uuids]'
  on '-j', '--json[=pretty/compact]', 'Output as JSON, instead of human-readable' do it || 'pretty' end
  on '-a', '--all', 'Also output TODOs which are complete [default just shows what is left]'
  on '-f', '--full', 'Print the full messages, not just up to the column width'
  on '-o', '--[no-]overdue', 'Only print overdue (or not overdue)'
  on '-p', '--priority=INTEGER', :priority, 'Only print tasks with the given priority'
  on '-t', '--tags=TAGLIST', Array, 'Only select tasks with all of the given tags'
  on '--sort=WHAT', %w[tags priority due], 'How to sort', default: :priority

  tasks = parse_and_tasks!(opts = {}).to_a
  tasks.select! { |task| $*.any? { task.uuid_matches? it } } unless $*.empty?
  tasks.reject!(&:complete?) unless opts[:all]
  tasks.select! { it.priority == opts[:priority] } if opts[:priority]
  tasks.select! { |task| opts[:tags].all? { task.tags.include? it } } if opts[:tags]
  out = []

  sort = opts[:sort].to_sym
  tasks.sort_by! { it.public_send(sort) || (sort == :priority ? 2.5 : nil) }
  out.concat tasks.select(&:overdue?) unless opts[:overdue] == false
  out.concat tasks.reject(&:overdue?) unless opts[:overdue] == true

  case opts[:json]
  when 'pretty' then puts JSON.pretty_generate out
  when 'compact' then puts out.to_json
  else
    warn "invalid key json: #{opts[:json]}" if opts.key? :json
    cols = opts[:full] ? nil : `tput cols`.to_i - 1 # if tput cols fails, it'll also be -1
    puts out.map { it.to_pretty_s[..cols] }
  end
end

def op.new!
  self.banner = "usage: #{program_name} [options] [task message, will be joined with spaces]" \
                "       #{program_name} [options] [-m/--multiple] 'task' [...]"

  on '-T', 'sets due date to tomorrow', key: :due do Time.now + 24*60*60 end
  on '-d', '--due=WHEN', :due, 'When the task is due [optional]'
  on '-c', '--complete', 'Already mark as already completed'
  on '-m', '--multiple', 'Create multiple tasks at once'
  on '-p', '--priority=INTEGER', :priority, 'How important it is (0 is most important)'
  on '-e', '--estimate=TIME', :estimate, 'How many minutes it will take take'
  on '-t', '--tags=TAGLIST', Array, 'List of tags to use'

  tasks = parse_and_tasks!(opts = {})
  task_messages = opts[:multiple] ? $*.dup : [$*.join(' ')]
  abort "#{opts[:multiple] ? "at least one" : "a"} task message must be supplied" if task_messages.empty?

  task_messages.each do |message|
    task = tasks.add(
      due: opts[:due]&.to_time,
      complete: !!opts[:complete],
      message:,
      priority: opts[:priority],
      estimate: opts[:estimate],
      tags: opts[:tags],
    )
    puts "create task: #{task}"
  end

  tasks.write!
end

def op.complete!
  banner.concat ' [uuids to complete]'
  on '-u', '--uncomplete', 'Mark tasks as uncompleted, instead of completed'

  tasks = parse_and_tasks!(opts = {})
  $*.empty? and abort 'at least one uuid must be given'

  success = true
  $*.each do |uuid|
    task = tasks.find_task(uuid)
    task.complete = !opts[:uncomplete]
    puts "marked task as #{opts[:uncomplete] ? "un" : ""}complete: #{task}"
  rescue Tasks::UUIDMatchError => err
    warn err
    success = false
  end

  tasks.write!
  exit success
end

def op.modify!
  banner.concat ' (uuids to modify)'

  on       '--delete', 'Completely deletes the task (dangerous! prefer --complete instead)'
  on '-c', '--complete', 'Mark task as completed'
  on '-u', '--uncomplete', 'Mark task as uncompleted, instead of completed', key: :complete do false end
  on '-d', '--[no-]due=WHEN', :due, 'Modify due date (or disables it)'
  on '-m', '--message=WHAT', 'Set the task message [must supply exactly one uuid]'
  on '-p', '--priority=INTEGER', Integer, 'How important it is (0 is most important)'
  on '-e', '--[no-]estimate=TIME', :estimate, 'How many minutes it will take take'
  on '-t', '--[no-]tags=TAGLIST', Array, 'List of tags to use'

  tasks = parse_and_tasks!(opts = {})
  # uuid = $*.shift
  # uuid.nil? || !$*.empty? and abort 'exactly one uuid must be given'

  tasks_to_modify = $*.map { begin tasks.find_task(it); rescue Tasks::UUIDMatchError; abort end }
  abort 'at least one uuid must be given' if tasks_to_modify.empty?
  abort 'can only supply --message when exactly one uuid is being modified' if opts.key?(:message) && tasks_to_modify.length != 1

  opts[:tags] = [] if opts[:tags] == false

  tasks_to_modify.each do |task|
    (task.complete = opts[:complete]; puts "changed complete to #{opts[:complete]} for: #{task}") if opts.key?(:complete)
    (task.due = opts[:due] ? opts[:due] : nil; puts "changed due to #{opts[:due]} for: #{task}") if opts.key?(:due)
    (task.message = opts[:message]; puts "changed message to #{opts[:message]} for: #{task}") if opts.key?(:message)
    (task.priority = opts[:priority]; puts "changed priority to #{opts[:priority]} for: #{task}") if opts.key?(:priority)
    (task.estimate = opts[:estimate] ? opts[:estimate] : nil; puts "changed estimate to #{opts[:estimate]} for: #{task}") if opts.key?(:estimate)
    (task.tags = opts[:tags]; puts "changed tags to #{opts[:tags]} for: #{task}") if opts.key?(:tags)

    if opts[:delete]
      tasks.tasks.delete task
      warn "deleted task: #{task} (#{task.to_json})"
    end
  end

  tasks.write!
end


case (cmd = $*.shift)
when 'raw' then x=XDG.new.state_home / 'sampshell' / 'todos' / 'current'; puts x; puts x.read
when nil, 'list' then op.list!
when 'new', 'add' then op.new!
when 'complete' then op.complete!
when 'modify' then op.modify!
when 'help' then op.help!
else op.abort "unknown command: #{cmd}; use #{op.program_name} help"
end
