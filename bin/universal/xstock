#!/usr/bin/env ruby

require 'xdg'
require 'optparse2'
require 'optparse2/pathname'
require 'open3'
require 'gvars'

OptParse2.new do |op|
  op.on '--[no-]debug', hidden: true

  op.on '-r', '--[no-]read', 'Read stock value from cached file'
  op.on '-w', '--[no-]write', 'Write fetched results to cached file'
  op.on '-p', '--period=SECONDS', Float, "If supplied, only read cached file if fewer than SECONDS has passed"
  op.on '--cache-folder=PATH', Pathname, 'Path to the cached folder',
    default: proc{ XDG.new.cache_home / 'sampshell' / 'stockprice' },
    default_description: '$XDG_CACHE_HOME/sampshell/stockprice'

  op.rest 'tickers', 'stock tickers to use', required: 1 do it.map(&:upcase) end

  op.parse! into: GVars rescue op.abort
end

if $debug
  def log = $stderr.puts("# #{yield}")
else
  def log = nil
end

def get_price(ticker)
  # ruby -rjson -e 'p JSON[`curl ''https://api.nasdaq.com/api/quote/AAPL/info?assetclass=stocks'' -s -H ''User-Agent: Mozilla/6.0''`].dig("data", "primaryData", "lastSalePrice")'
  out, ok = Open3.capture2('curl', '-s',
    "https://www.google.com/finance/quote/#{ticker}")
  raise "unable to get ticker for #{ticker}: exit status #{ok.exitstatus}" unless ok.success?
  # puts out
  out[/data-last-price="([^"]*)"/, 1] or abort "unable to get stock for: #{ticker}"
end

$tickers.each do |ticker|
  if $read || $write
    $cache_file = $cache_folder / ticker
  end

  if $read
    if ! $cache_file.exist?
      log { "cache file #$cache_file does not exist; cannot read" }
    else
      $old_value = $cache_file.read

      if $old_value.empty?
        warn "old value empty, not using"
      elsif $period && ($cache_file.mtime + $period > Time.now)
        log { "using cached value for #{ticker} (from #$cache_file): #$old_value" }
        puts "#$old_value"
        exit
      end
    end
  end

  $price = get_price(ticker)
  log { "got price for #{ticker}: #$price" }

  if $write
    $cache_file.parent.mkpath
    log { "writing cached value for #{ticker} (to #$cache_file): #$price" }
    $cache_file.write("#$price\n")
  end

  printf "%s\t%s\n", ticker, $price
end
