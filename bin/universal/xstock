#!/usr/bin/env ruby
# This file is janky

require 'sscript'
require 'optparse2'
require 'optparse2/globals'
require 'optparse2/pathname'
require 'open3'
require 'fileutils'

OptParse2.new do |op|
	op.on '-V', '--[no-]verbose' do $-v = true end
	op.on '-t', '--ticker=TICKER', 'The stock ticker to use', &:upcase

	op.on '--period=SECONDS', Float, 'If supplied, don\'t query if `--cache-file` was modified less than PERIOD seconds ago', default: 3600.0
	op.on '-f', '--flush', 'Forcibly write to the out file; if neither period nor flush are give, nothing is written'
	op.on '--[no-]cache-file=PATH', Pathname, 'Path to write results to', default: (
		Pathname(ENV.fetch_nonempty('XDG_CACHE_HOME', '~/.cache')) / 'sampshell' / 'stockprice'
	)

	op.parse! into: OptParse2::Globals rescue op.abort
	defined?($flush) && $flush and $period = 0
	op.abort 'no arguments allowed' unless $*.empty?
	op.abort 'no ticker given' unless $ticker
end

def get_price(ticker)
	out, ok = Open3.capture2('curl', '-s',
		"https://www.google.com/finance/quote/#{ticker}:NYSE")
	raise "unable to get ticker for #{ticker}: exit status #{ok.exitstatus}" unless ok.success?
	# puts out
	out[/data-last-price="([^"]*)"/, 1]
end

if $cache_file
	if ! $cache_file.exist?
		FileUtils.mkdir_p $cache_file.parent
	else
		$old_value = File.read($cache_file)
		if $period && ($cache_file.mtime + $period > Time.now)
			$VERBOSE and $stderr.puts "# using cached value for #$ticker (from #$cache_file): #$old_value"
			puts "#$old_value"
			exit
		end
	end
end

$price = get_price($ticker)
$VERBOSE and $stderr.puts "# got price for #$ticker: #$price"

if $cache_file
	$VERBOSE and $stderr.puts "# writing cached value for #$ticker (to #$cache_file): #$price"
	$cache_file.write("#$price\n")
end

puts $price
