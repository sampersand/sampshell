#!/usr/bin/env ruby

require 'optparse2'
require 'optparse/date'
require 'gvars'

def git_config(key)
  `git config --get #{key}`.chomp.tap { raise unless $?.success? }
end

OptParse2.new do |op|
  op.on '-d', '--date=DATE', Date, 'Set the date.',    default: proc{Date.today}, default_description: 'today'
  op.on '-p', '--prefix=PREFIX', 'Set branch prefix.', default: proc{ git_config('sampshell.branchPrefix') }
  op.on '-s', '--sep=SEP', 'Set the separator.',       default: proc{ git_config('sampshell.branchSeparator') }
  op.rest 'branch name', 'name of the branch (separated by -)', required: 1 do it.join '-' end
  op.parse! into: GVars, abort: true
end

puts [$prefix, $date, $branch_name].join($sep)
