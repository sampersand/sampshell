IS_MACOS = RUBY_PLATFORM.include? 'darwin'

# Delete empty targets: Empty files, Empty Dirs, and Dirs that just contain `.DS_Store`
def delete_empty_target(target)
  case File.ftype(target)
  when 'file'
    return unless File.empty?(target)
      puts "removing empty file: #{target}" if verbose?
      File.unlink target
    end

  when 'directory'
    # TODO: Sanity check and only delete if it's the only file in it
    if IS_MACOS
      ds = File.join(target, '.DS_Store')
      puts "Removing .DS_Store: #{ds}" if verbose?
      File.unlink ds if File.exist?(ds)
    end

    if Dir.empty?(target)
      puts "removing empty folder: #{target}" if verbose?
      Dir.rmdir target
    end

  else
    # Do nothing, we don't handle these types here
  end
end

