#!/bin/sh

## A script to print out entries in `$PATH`

set -euC # Safety first
readonly script_name=${0##*/}

# Print a message and exit
die () {
	fmt="%s: $1\n"
	shift
	printf >&2 "$fmt" "$script_name" "$@"
	exit 1
}

################################################################################
#                                Parse CLI opts                                #
################################################################################

usage () { cat; } <<EOS
usage: $script_name [-a] [-f | -n | -d] [-p | -P SHELL]
       $script_name [-a] [-f | -n | -d] [path]
Prints all executables found in the given path

	-a        also include non-executable files and non-existent directories
	-f        print the entire path of executables [default]
	-n        print the name of executables, not their full path
	-d        print directories containing at least one executable
	-p        use the default system \$PATH (via 'getconf')
	-P SHELL  get the default path for SHELL (via '\$SHELL -c printf \$PATH')
	path      colon-separated list of directories to search [default=\$PATH]
EOS


mode=full
all=
default_path=
default_path_shell=

while getopts 'hpafndP:' opt
do
	case $opt in
	p) default_path=1 default_path_shell= ;;
	P) default_path= default_path_shell=$OPTARG ;;
	a) all=1 ;;
	f) mode=full ;;
	n) mode=name ;;
	d) mode=dir ;;
	h) usage; exit ;;
	*) usage >&2; exit 2
	esac
done

shift $(( OPTIND - 1 ))

################################################################################
#                          Determine the $PATH to use                          #
################################################################################


if [ -n "$default_path" ]
then
	[ $# -ne 0 ] && die 'cannot supply -p and a path'
	path_to_search=$(getconf PATH && echo .) || \
		die 'cannot fetch default $PATH'
	path_to_search=${path_to_search%?.}
elif [ -n "$default_path_shell" ]
then
	[ $# -ne 0 ] && die 'cannot supply -P and a path'
	path_to_search=$(env -i "$default_path_shell" -c 'printf %s. "$PATH"') || \
		die "Cannot get default path for shell %s" "$default_path_shell"
	path_to_search=${path_to_search%.}
elif [ $# -le 1 ]
then
	path_to_search=${1-$PATH}
else
	usage >&2
	exit 2
fi


################################################################################
#                              Perform the Checks                              #
################################################################################

IFS=:
for dir in $path_to_search
do
	# Legacy artifact: empty path segments are actually `.`
	if [ -z "$dir" ]
	then
		dir=.
	fi

	# Check to make sure the directory even exists
	if [ ! -d "$dir" ] || [ ! -x "$dir" ]
	then
		if [ -n "$all" ] && [ $mode = dir ]
		then
			printf '%s\n' "$dir"
		fi

		continue
	fi

	# If we're in directory mode, just print out the dir
	if [ $mode = dir ]
	then
		printf '%s\n' "$dir"
		continue
	fi

	for file in "$dir"/* "$dir"/.*
	do
		# Make sure the file even exists (get around glob problems)
		if [ ! -f "$file" ]
		then
			continue
		fi

		# Make sure it's executable (or `-a` was passed)
		if [ -z "$all" ] && [ ! -x "$file" ]
		then
			continue
		fi

		# Print out the the file; `##*/` is safe here because we know
		# that the expansion will give us files and not end in `/`
		if [ $mode = name ]
		then
			printf '%s\n' "${file##*/}"
		else
			printf '%s\n' "$file"
		fi
	done
done
