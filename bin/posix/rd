#!/bin/sh

## Remove an empty directory; A single `.DS_Store` file in the directory
## Change the `rd` function to remove `.DS_Store` before doing `rmdir`.

# Safety first!
set -euC

readonly scriptname=${0##*/}

usage () { cat; } <<USAGE
usage: $scriptname [-rev] dir [..]

Alias for 'rmdir', except it'll also remove directories which
only contain a '.DS_Store' file. (.DS_Store is a hidden macOS
file in each directory Finder.app opens to store GUI info, eg
file positions, "preview icon size", etc. If we are trying to
remove an empty directory, then it can be removed too.)

The '-r' flag will recursively go into directories
The '-e' flag exits early if there's any problems; normally, problems are ignored.
The '-v' flag sets verbose mode; prints out each folders as theyre remvoed
USAGE

################################################################################
#                                Parse Options                                 #
################################################################################

recursive= exit_early= verbose=
while getopts 'hrev' option; do
	case $option in
	h) usage; exit ;;
	r) recursive=1 ;;
	e) exit_early=1 ;;
	v) verbose=1 ;;
	*) exit 2 ;;
	esac
done

shift $(( OPTIND - 1 ))

# Require at least one string as an argument
if [ $# -eq 0 ]; then
	usage >&2
	exit 1
fi

################################################################################
#                                Helper Methods                                #
################################################################################

# Define the `log_file_for_deletion` method only to print files as they're
# deleted if verbose mode is enabled
if [ -n "$verbose" ]; then
	log_file_for_deletion () { printf '%s\n' "$1"; }
else
	log_file_for_deletion () { :; }
fi

# Handle failure conditions during the script; if an early exit is requested,
# then we exit immediately. Normally, though, we just set the `exit_status`
# which is reported at the end of the script
exit_status=0
if [ -n "$exit_status" ]; then
	set_exit_status () { exit 1; }
else
	set_exit_status () { exit_status=1; }
fi

# Warn prints a message to stderr, then sets the exit status. It prepends the
# script name, and appends a newline, for ease-of-use.
warn () {
	fmt="%s: $1\n"
	shift
	printf "$fmt" "$scriptname" "$@" >&2
	set_exit_status
}
################################################################################
#                             Meat of the Program                              #
################################################################################

# Removes an empty directory, deleting any `.DS_Store`s which may exist (and
# also recursively descending into child directories if `-r` was supplied)
# first. Any deleted files are logged if verbose mode is enabled.
remove_directory () {
	# If it's not a directory, then just set the error, and return
	if [ ! -d "$1" ]; then
		warn '%s: Not a directory' "$1"
		return
	fi

	# If there's a `.DS_Store` file, go ahead and remove it
	if [ -e "$1"/.DS_Store ]; then
		log_file_for_deletion "$1/.DS_Store"
		if ! command -p rm -f -- "$1"/.DS_Store; then
			set_exit_status
			return
		fi
	fi

	# if there are files in the folder, and we're recursive, then delete them
	if command -p ls -A1q -- "$1" | command -p grep -q . && [ -n "$recursive" ]; then
		for file in "$1"/* "$1"/.*; do
			# If it doesn't exist, or is `.` or `..`, then ignore it
			[ -e "$file" ] || continue
			case $file in */.|*/..) continue; esac

			if [ -d "$file" ]; then
				remove_directory "$file"
			fi
		done
	fi

	# Remove the directory; if there's a problem, set the exit status.
	log_file_for_deletion "$1"
	command -p rmdir -- "$1" || set_exit_status
}


# Remove each directory argument supplied
for directory; do
	remove_directory "$directory"
done

# Exit with the exit status
exit $exit_status
